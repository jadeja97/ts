{
  "name": "@jadeja/ts",
  "description": "an opinionated TypeScript toolkit",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "exports": {
    "./configs/ts/*": {
      "import": "./dist/configs/ts/*.json",
      "default": "./dist/configs/ts/*.json"
    },
    "./configs/*": {
      "types": "./dist/configs/*.d.ts",
      "import": "./dist/configs/*.js",
      "default": "./dist/configs/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js",
      "default": "./dist/plugins/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.d.ts",
      "default": "./dist/types/*.d.ts"
    }
  },
  "scripts": {
    "prepare": "husky",
    "check": "tsc && oxfmt --check --disable-nested-config && oxlint --disable-nested-config",
    "fix": "oxlint --fix --disable-nested-config && oxfmt --disable-nested-config",
    "build": "pnpm check && vite build",
    "publish-it": "pnpm build && pnpm publish --tag alpha --access public --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3",
    "unplugin-dts": "^1.0.2",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "oxfmt": "^0.48.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "keywords": [
    "ts",
    "toolkit",
    "typescript",
    "configs",
    "oxfmt",
    "oxlint",
    "tsconfig",
    "lib",
    "plugins"
  ],
  "files": [
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "dist"
  ],
  "homepage": "https://github.com/JadejaHQ/ts",
  "bugs": "https://github.com/JadejaHQ/ts/issues",
  "license": "MIT",
  "author": {
    "name": "Pradipsinh Jadeja",
    "email": "224366804+jadeja97@users.noreply.github.com",
    "url": "https://x.com/jadeja97_"
  },
  "contributors": [
    {
      "name": "Pradipsinh Jadeja",
      "email": "224366804+jadeja97@users.noreply.github.com",
      "url": "https://x.com/jadeja97_"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JadejaHQ/ts.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10",
    "turbo": ">=2",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "error"
    }
  }
}
