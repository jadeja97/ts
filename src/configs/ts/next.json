{
  "extends": "./base.json",
  "compilerOptions": {
    "types": ["node", "react", "react-dom"],
    "lib": ["dom", "dom.iterable", "ESNext"],
    "jsx": "react-jsx",
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowJs": false,
    "incremental": false,
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  }
}
